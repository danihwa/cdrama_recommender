# Python bytecode & build artifacts
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/

# Virtualenvs — the container builds its own with uv
.venv/
venv/
env/
ENV/

# Test, lint & type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Jupyter
.ipynb_checkpoints/

# Secrets — mount at runtime, never bake into the image
.env
.env.local
.env.*.local
*.pem
*.key

# Editor / OS cruft
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Node (for Python projects with a JS frontend)
node_modules/

# NOTE: .git is deliberately NOT excluded — Claude needs git history
# (log, blame, status, diff) to work inside the container.
